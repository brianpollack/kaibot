{
  "name": "kaibot",
  "version": "0.19.0",
  "description": "Protovate KaiBot is an AI Agent Wrapper that helps process project changes through an AI LLM with change tracking",
  "author": "Brian Pollack - Protovate",
  "type": "module",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:all": "npm run build && npm run build:electron",
    "dev": "tsx src/index.ts",
    "bot": "tsx src/kai_bot.ts",
    "local": "tsx src/kai_bot.ts .",
    "feature": "tsx src/kai_bot.ts feature",
    "models": "tsx src/kai_bot.ts models",
    "start": "node dist/index.js",
    "electron": "npm run build:all && electron .",
    "electron:pack": "npm run build:all && electron-builder",
    "electron:pack:mac": "npm run build:all && electron-builder --mac",
    "electron:pack:win": "npm run build:all && electron-builder --win",
    "dist:mac": "npm run build:all && electron-builder --mac --publish always",
    "dist:win": "npm run build:all && electron-builder --win --publish always",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:openrouter": "vitest run --config vitest.openrouter.config.ts",
    "test:real": "tsx src/kai_test_real.ts",
    "testOpenrouter": "tsx src/kai_bot.ts testOpenrouter",
    "latest": "npm install @anthropic-ai/claude-agent-sdk@latest @linear/sdk@latest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.87",
    "@linear/sdk": "^80.0.0",
    "adm-zip": "^0.5.17",
    "electron-updater": "^6.8.3",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9",
    "prettier": "^3",
    "tsx": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^3"
  }
}
