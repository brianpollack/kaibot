{
  "name": "kaibot",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "bot": "tsx src/kai_bot.ts",
    "local": "tsx src/kai_bot.ts .",
    "models": "tsx src/kai_bot.ts models",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:real": "tsx src/kai_test_real.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "eslint": "^9",
    "prettier": "^3",
    "tsx": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^3"
  }
}
